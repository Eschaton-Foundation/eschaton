        "code": "<?php\r\n\r\n\/\/ CWP Format Error Response\r\nif (!function_exists('cwpErrorMessage')) {\r\n\tfunction cwpErrorMessage($response){\r\n\t\t$message = is_array($response) ? 'Error!! ' . $response['messages'][0]['message'] : 'Error!! ' . $response;\r\n\t\techo '<div style=\"background: #fff; border: 1px solid #c3c4c7; border-left-width: 4px; border-left-color: #d63638; box-shadow: 0 1px 1px rgba(0, 0, 0, .04); margin: 5px 0 25px; padding: 1px 12px;\">' .\r\n\t\t\t '<p style=\"margin: .5em 0; padding: 2px; font-size: 0.875em; color: #444;\">' . esc_html($message) . '<\/p>' .\r\n\t\t\t '<\/div>';\r\n\t}\r\n}\r\n\r\n\/\/ CWP Format Warning Response\r\nif (!function_exists('cwpWarningMessage')) {\r\n\tfunction cwpWarningMessage($response){\r\n\t\t$message = is_array($response) ? 'Warning!! ' . $response['messages'][0]['message'] : 'Error!! ' . $response;\r\n\t\techo '<div style=\"background: #fff; border: 1px solid #c3c4c7; border-left-width: 4px; border-left-color: #00a32a; box-shadow: 0 1px 1px rgba(0, 0, 0, .04); margin: 5px 0 25px; padding: 1px 12px;\">' .\r\n\t\t\t '<p style=\"margin: .5em 0; padding: 2px; font-size: 0.875em; color: #444;\">' . esc_html($message) . '<\/p>' .\r\n\t\t\t '<\/div>';\r\n\t}\r\n}\r\n\r\n\/\/ CWP Format Success Response\r\nif (!function_exists('cwpSuccessMessage')) {\r\n\tfunction cwpSuccessMessage($response){\r\n\t\t$message = is_array($response) ? 'Success!! ' . $response['messages'][0]['message'] : 'Error!! ' . $response;\r\n\t\techo '<div style=\"background: #fff; border: 1px solid #c3c4c7; border-left-width: 4px; border-left-color: #00a32a; box-shadow: 0 1px 1px rgba(0, 0, 0, .04); margin: 5px 0 25px; padding: 1px 12px;\">' .\r\n\t\t\t '<p style=\"margin: .5em 0; padding: 2px; font-size: 0.875em; color: #444;\">' . esc_html($message) . '<\/p>' .\r\n\t\t\t '<\/div>';\r\n\t}\r\n}\r\n\r\n\r\n\r\n",
