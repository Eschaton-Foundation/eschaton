        "code": "<?php\r\n\r\n\/**\r\n * CWP Snippets - Test Function Execution\r\n *\r\n * This function adds a visible message to the page to confirm execution.\r\n *\/\r\nfunction cwp_test_function_execution() {\r\n    \/\/ Check if headers have already been sent to avoid errors\r\n    if (headers_sent()) {\r\n        error_log(\"CWP Test Function: Cannot output message, headers already sent.\");\r\n        return;\r\n    }\r\n\r\n    \/\/ Determine context for the message\r\n    $context = is_admin() ? 'Admin Area' : 'Frontend';\r\n\r\n    \/\/ Output the message div with only the ID\r\n    \/\/ --- MODIFIED THIS LINE ---\r\n    echo '<div id=\"cwp-function-test-message\">';\r\n    echo 'CWP Function Snippet Executed Successfully in: ' . esc_html($context);\r\n    echo '<\/div>';\r\n}\r\n\r\n\/\/ Call the function immediately (since it's evaluated within the injection function)\r\ncwp_test_function_execution();\r\n\r\n?>\r\n\r\n",
